# NovaShield NGFW — Environment Variables
# Copy this file to .env and update values for your deployment.

# JWT secret shared between gateway and backend (MUST change in production)
NOVA_JWT_SECRET=novashield-production-secret-change-me

# AI Engine configuration
NOVA_AI_ENGINE_URL=http://ai_engine:8000
NOVA_AI_ENABLED=true

# Redis configuration
NOVA_REDIS_URL=redis://redis:6379

# Backend URL (used by gateway to proxy requests)
NOVA_BACKEND_URL=http://backend:8081

# Rust log level
RUST_LOG=gateway=info,backend=info
